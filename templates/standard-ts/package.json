{
    "name": "typesharp-standard-ts-template",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "typecheck": "tsc --noEmit",
        "lint": "eslint \"src/**/*.ts\" \"types/**/*.d.ts\"",
        "format": "prettier --check .",
        "format:write": "prettier --write ."
    },
    "devDependencies": {
        "@eslint/js": "^9.18.0",
        "eslint": "^9.18.0",
        "prettier": "^3.4.2",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.20.0"
    }
}
